{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "python": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "permission": {
    "lsp": "allow"
  }
}
